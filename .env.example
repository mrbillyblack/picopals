# Copy to .env and adjust as needed.
# ---- MySQL ----
MYSQL_ROOT_PASSWORD=rootpass_change_me
MYSQL_DATABASE=picopals
MYSQL_USER=tama
MYSQL_PASSWORD=tama_change_me

# ---- Backend ----
# Used by FastAPI. Inside docker these hostnames resolve to the service names.
DATABASE_URL=mysql+pymysql://tama:tama_change_me@mysql:3306/picopals
REDIS_URL=redis://redis:6379/0
# Comma separated list of allowed origins for CORS during local `vite dev`.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ---- Frontend (build-time) ----
# Same-origin in production (Caddy proxies /api). Override for split dev.
VITE_API_BASE=/api
