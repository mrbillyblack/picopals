# Copy to .env and adjust as needed.
# ---- MySQL ----
# SECURITY: change ALL of these before any non-local deployment. The defaults
# below are placeholders only.
MYSQL_ROOT_PASSWORD=rootpass_change_me
MYSQL_DATABASE=picopals
MYSQL_USER=tama
MYSQL_PASSWORD=tama_change_me

# ---- Backend ----
# Used by FastAPI. Inside docker these hostnames resolve to the service names.
DATABASE_URL=mysql+pymysql://tama:tama_change_me@mysql:3306/picopals
REDIS_URL=redis://redis:6379/0
# Comma separated list of allowed origins for CORS during local `vite dev`.
# Keep this tight in production (never "*"): credentials are allowed.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Expose Swagger UI / OpenAPI schema. Leave false in production.
ENABLE_DOCS=false
# Per-IP rate limiting (brute-force / DoS guard). Uses REDIS_URL for storage.
RATE_LIMIT_ENABLED=true
# Pet stat-decay timescale. Larger = slower decay (pet can be left longer).
# 1 = original fast timings; 24 (default) ~ a hunger heart every ~1.2h; 48 ~ daily.
PET_DECAY_SCALE=24

# ---- Frontend (build-time) ----
# Same-origin in production (Caddy proxies /api). Override for split dev.
VITE_API_BASE=/api
