# Development image: runs the Vite dev server with hot-module reload.
# Used by docker-compose.dev.yml. Source is bind-mounted at runtime; an
# anonymous volume keeps the image's node_modules from being shadowed.
FROM node:20-alpine
WORKDIR /app

COPY package.json package-lock.json ./
RUN npm ci

COPY . .

EXPOSE 5173
# --host exposes the dev server outside the container.
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
